# Required: Vercel AI Gateway URL (from Vercel dashboard → AI Gateway)
# Configure your provider (Anthropic, OpenAI, Google, etc.) in the gateway dashboard.
VERCEL_AI_GATEWAY_URL=https://ai-gateway.vercel.sh

# Optional: Only needed if your gateway is configured for key passthrough.
# If you've added the Anthropic key directly in the AI Gateway dashboard, leave this unset.
ANTHROPIC_API_KEY=sk-ant-...
